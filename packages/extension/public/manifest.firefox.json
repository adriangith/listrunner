{
  "manifest_version": 3,
  "name": "ListRunner",
  "version": "0.1.0",
  "description": "Shopping list wizard — step through your list on any online store",
  "permissions": [
    "storage",
    "contextMenus",
    "activeTab",
    "scripting"
  ],
  "background": {
    "scripts": ["service-worker.js"],
    "type": "module"
  },
  "sidebar_action": {
    "default_panel": "side-panel.html",
    "default_title": "ListRunner",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content-script.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Open ListRunner"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "listrunner@anthropic.local",
      "strict_min_version": "115.0"
    }
  }
}
